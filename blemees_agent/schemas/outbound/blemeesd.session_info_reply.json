{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/blemeesd.session_info_reply.json",
  "title": "blemeesd.session_info_reply",
  "description": "Snapshot of per-session counters maintained by the daemon. Fields inside last_turn_usage / cumulative_usage are accumulated from the normalised agent.result.usage block; new keys may appear as backends grow (additionalProperties: true).",
  "type": "object",
  "properties": {
    "type": { "const": "blemeesd.session_info_reply" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "backend": { "$ref": "https://blemees/schemas/_common.json#/$defs/Backend" },
    "native_session_id": { "type": "string" },
    "model": { "type": ["string", "null"] },
    "cwd": { "type": ["string", "null"] },
    "turns": { "type": "integer", "minimum": 0 },
    "last_turn_at_ms": { "type": ["integer", "null"], "minimum": 0 },
    "last_turn_usage": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "cumulative_usage": { "$ref": "https://blemees/schemas/_common.json#/$defs/NormalisedUsage" },
    "context_tokens": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of the last turn's input-side tokens (fresh + cache_read + cache_creation). Use against the model's context window to estimate headroom."
    },
    "attached": { "type": "boolean" },
    "subprocess_running": { "type": "boolean" },
    "last_seq": { "type": "integer", "minimum": 0 }
  },
  "required": [
    "type",
    "session_id",
    "backend",
    "turns",
    "last_turn_usage",
    "cumulative_usage",
    "context_tokens",
    "attached",
    "subprocess_running",
    "last_seq"
  ],
  "additionalProperties": true
}

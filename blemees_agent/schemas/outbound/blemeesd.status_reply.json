{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/blemeesd.status_reply.json",
  "title": "blemeesd.status_reply",
  "description": "Point-in-time snapshot of the daemon's internal state: version info, uptime, connection/session counters, effective config, detected backends.",
  "type": "object",
  "properties": {
    "type": { "const": "blemeesd.status_reply" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "daemon": { "type": "string" },
    "protocol": { "type": "string" },
    "pid": { "type": "integer" },
    "uptime_s": { "type": "number", "minimum": 0 },
    "socket_path": { "type": "string" },
    "backends": {
      "type": "object",
      "description": "Map of backend name → version string detected at startup. Same shape as blemeesd.hello_ack.backends.",
      "additionalProperties": { "type": "string" }
    },
    "connections": { "type": "integer", "minimum": 0 },
    "sessions": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "attached": { "type": "integer", "minimum": 0 },
        "detached": { "type": "integer", "minimum": 0 },
        "active_turns": { "type": "integer", "minimum": 0 },
        "by_backend": {
          "type": "object",
          "description": "Per-backend session counts. Sum across keys equals total.",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      },
      "required": ["total", "attached", "detached", "active_turns"],
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "description": "Effective subset of Config; forward-compatible (new knobs may appear).",
      "additionalProperties": true
    }
  },
  "required": ["type", "daemon", "protocol", "pid", "uptime_s", "backends", "sessions", "config"],
  "additionalProperties": true
}

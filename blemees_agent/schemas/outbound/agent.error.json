{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/agent.error.json",
  "title": "agent.error",
  "description": "Daemon error frame. `code` is machine-readable; `message` is for humans. Session-stream errors (backend_crashed, auth_failed) carry `seq`; handshake/dispatcher errors do not.",
  "type": "object",
  "properties": {
    "type": { "const": "agent.error" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "backend": { "$ref": "https://blemees/schemas/_common.json#/$defs/Backend" },
    "code": {
      "type": "string",
      "enum": [
        "protocol_mismatch",
        "invalid_message",
        "unknown_message",
        "unknown_backend",
        "unsafe_flag",
        "session_unknown",
        "session_exists",
        "session_busy",
        "spawn_failed",
        "backend_crashed",
        "auth_failed",
        "oversize_message",
        "slow_consumer",
        "daemon_shutdown",
        "internal"
      ]
    },
    "message": { "type": "string" },
    "seq": { "$ref": "https://blemees/schemas/_common.json#/$defs/Seq" }
  },
  "required": ["type", "code", "message"],
  "additionalProperties": true
}

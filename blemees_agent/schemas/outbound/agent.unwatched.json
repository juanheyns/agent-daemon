{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/agent.unwatched.json",
  "title": "agent.unwatched",
  "description": "Reply to agent.unwatch. was_watching indicates whether this connection actually had a subscription to remove.",
  "type": "object",
  "properties": {
    "type": { "const": "agent.unwatched" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "was_watching": { "type": "boolean" }
  },
  "required": ["type", "session_id"],
  "additionalProperties": true
}

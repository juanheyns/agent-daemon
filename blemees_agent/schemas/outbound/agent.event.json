{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/agent.event.json",
  "title": "agent.* (unified event envelope)",
  "description": "Every translated event the daemon forwards lives under the agent.* namespace. There are eight types (system_init, delta, message, user_echo, tool_use, tool_result, notice, result). The full type-by-type mapping from each backend's native event is in docs/agent-events.md — this schema constrains the envelope and the per-type required fields, leaving inner shapes (e.g. the `content` array) intentionally permissive so future block types pass through.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "agent.system_init",
        "agent.delta",
        "agent.message",
        "agent.user_echo",
        "agent.tool_use",
        "agent.tool_result",
        "agent.notice",
        "agent.result"
      ]
    },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "seq": { "$ref": "https://blemees/schemas/_common.json#/$defs/Seq" },
    "backend": { "$ref": "https://blemees/schemas/_common.json#/$defs/Backend" },
    "raw": {
      "description": "Optional native event the daemon translated from. Present only when the session was opened with options.<backend>.include_raw_events:true. Synthetic frames assembled from multiple native events omit this field."
    }
  },
  "required": ["type", "session_id", "seq", "backend"],
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "agent.system_init" } } },
      "then": {
        "properties": {
          "model": { "type": ["string", "null"] },
          "cwd": { "type": ["string", "null"] },
          "tools": { "type": "array", "items": { "type": "string" } },
          "native_session_id": { "type": ["string", "null"] },
          "capabilities": { "type": "object", "additionalProperties": true },
          "context_window": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.delta" } } },
      "then": {
        "properties": {
          "kind": { "type": "string", "enum": ["text", "thinking", "tool_input"] },
          "text": { "type": "string" },
          "partial_json": { "type": "string" },
          "index": { "type": "integer", "minimum": 0 },
          "item_id": { "type": "string" },
          "tool_use_id": { "type": "string" }
        },
        "required": ["kind"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.message" } } },
      "then": {
        "properties": {
          "role": { "const": "assistant" },
          "content": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "phase": { "type": "string" }
        },
        "required": ["role", "content"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.user_echo" } } },
      "then": {
        "properties": {
          "message": { "$ref": "https://blemees/schemas/_common.json#/$defs/AgentUserMessage" }
        },
        "required": ["message"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.tool_use" } } },
      "then": {
        "properties": {
          "tool_use_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "input": { "description": "Tool input. Type depends on the tool; usually an object." }
        },
        "required": ["tool_use_id", "name", "input"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.tool_result" } } },
      "then": {
        "properties": {
          "tool_use_id": { "type": "string", "minLength": 1 },
          "output": { "description": "Tool output. String or array of content blocks; backend-specific." },
          "is_error": { "type": "boolean" }
        },
        "required": ["tool_use_id", "output"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.notice" } } },
      "then": {
        "properties": {
          "level": { "type": "string", "enum": ["info", "warn"] },
          "category": { "type": "string", "minLength": 1 },
          "text": { "type": "string" },
          "data": { "type": "object", "additionalProperties": true }
        },
        "required": ["level", "category"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "agent.result" } } },
      "then": {
        "properties": {
          "subtype": {
            "type": "string",
            "enum": ["success", "error", "interrupted", "max_turns", "max_budget"]
          },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "num_turns": { "type": "integer", "minimum": 0 },
          "turn_id": { "type": "string" },
          "time_to_first_token_ms": { "type": "integer", "minimum": 0 },
          "usage": { "$ref": "https://blemees/schemas/_common.json#/$defs/NormalisedUsage" },
          "error": {
            "type": "object",
            "description": "Present when subtype:'error'. Carries the backend's error payload (CC: stderr tail or system event; Codex: JSON-RPC error.data).",
            "additionalProperties": true
          }
        },
        "required": ["subtype"]
      }
    }
  ],
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/inbound/blemeesd.open.json",
  "title": "blemeesd.open",
  "description": "Open or reattach a session. Most fields map 1:1 to `claude -p` flags (see spec §5.4). Unset fields produce no flag; the daemon passes through CC defaults.",
  "type": "object",
  "properties": {
    "type": { "const": "blemeesd.open" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "resume": {
      "type": "boolean",
      "default": false,
      "description": "If true, spawn `claude -p --resume <session>`; allows reattaching a detached session."
    },
    "last_seen_seq": {
      "type": "integer",
      "minimum": 0,
      "description": "Highest `seq` the client has observed. Daemon replays ring buffer entries with `seq > last_seen_seq` before resuming live stream. Omit to skip replay."
    },

    "model": { "type": "string" },
    "system_prompt": { "type": "string" },
    "append_system_prompt": { "type": "string" },
    "tools": { "type": "string", "description": "Empty string disables all tools." },
    "disallowed_tools": { "type": "array", "items": { "type": "string" } },
    "permission_mode": {
      "type": "string",
      "enum": ["default", "acceptEdits", "bypassPermissions", "plan"]
    },
    "cwd": { "type": "string" },
    "add_dir": { "type": "array", "items": { "type": "string" } },
    "effort": { "type": "string" },
    "agent": { "type": "string" },
    "agents": {
      "oneOf": [{ "type": "object" }, { "type": "string" }],
      "description": "Serialized to JSON on the CLI."
    },
    "mcp_config": { "type": "array", "items": { "type": "string" } },
    "strict_mcp_config": { "type": "boolean" },
    "settings": { "type": "string" },
    "setting_sources": { "type": "string" },
    "plugin_dir": { "type": "array", "items": { "type": "string" } },
    "betas": { "type": "array", "items": { "type": "string" } },
    "exclude_dynamic_system_prompt_sections": { "type": "boolean" },
    "max_budget_usd": { "type": "number", "minimum": 0 },
    "json_schema": {
      "oneOf": [{ "type": "object" }, { "type": "string" }]
    },
    "fallback_model": { "type": "string" },
    "session_name": { "type": "string" },
    "session_persistence": { "type": "boolean" },
    "include_partial_messages": { "type": "boolean" },
    "replay_user_messages": { "type": "boolean" }
  },
  "required": ["type", "session_id"],
  "not": {
    "anyOf": [
      { "required": ["dangerously_skip_permissions"] },
      { "required": ["allow_dangerously_skip_permissions"] },
      { "required": ["bare"] },
      { "required": ["continue"] },
      { "required": ["from_pr"] },
      { "required": ["input_format"] },
      { "required": ["output_format"] }
    ]
  },
  "additionalProperties": true
}

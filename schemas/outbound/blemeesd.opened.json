{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blemees/schemas/outbound/blemeesd.opened.json",
  "title": "blemeesd.opened",
  "description": "Reply to blemeesd.open on success. `last_seq` is the highest seq the session has produced at this moment — clients can compare to their `last_seen_seq` to decide if a replay is in flight.",
  "type": "object",
  "properties": {
    "type": { "const": "blemeesd.opened" },
    "id": { "$ref": "https://blemees/schemas/_common.json#/$defs/RequestId" },
    "session_id": { "$ref": "https://blemees/schemas/_common.json#/$defs/SessionId" },
    "subprocess_pid": { "type": "integer" },
    "last_seq": { "type": "integer", "minimum": 0 }
  },
  "required": ["type", "session_id"],
  "additionalProperties": true
}
